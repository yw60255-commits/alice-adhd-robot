# ============================================================
# ALICE ADHD Robot — 环境配置模板
# 复制此文件为 .env 并填写实际的值
# 注意：不要上传到 GitHub！
# ============================================================

# ── 1. OpenRouter（统一入口）─────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── 2. 模型配置 ──────────────────────────────────────────────
VARIANT_A_MODEL=z-ai/glm-5-turbo
VARIANT_B_MODEL=anthropic/claude-sonnet-4
DEEPSEEK_MODEL=deepseek/deepseek-chat-v3-0324
MAX_TOKENS=500
TEMPERATURE=0.7

# ── 3. STT：Deepgram ─────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
STT_MODEL=nova-2
STT_LANGUAGE=zh-HK
STT_DETECT_LANGUAGE=true
STT_PUNCTUATE=true
STT_INTERIM_RESULTS=false

# ── 4. TTS：Fish Audio ───────────────────────────────────────
FISH_API_KEY=your_fish_audio_api_key_here
FISH_API_BASE=https://api.fish.audio/v1/tts
TTS_MODEL=s2-pro
TTS_SPEED=0.85
TTS_FORMAT=mp3
TTS_DEFAULT_EMOTION=warm
TTS_TRANSITION_EMOTION=calm
TTS_REDIRECT_EMOTION=gentle

# ── 5. 功能开关 ──────────────────────────────────────────────
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_AB_TESTING=false
ENABLE_SAFETY_FENCE=true
ENABLE_SESSION_LOGGING=true
ENABLE_MTR_INTEGRATION=false

# ── 6. A/B 测试 ──────────────────────────────────────────────
AB_VARIANT_A=zhipuai/glm-4
AB_VARIANT_B=anthropic/claude-sonnet-4
AB_SPLIT_RATIO=0.5
AB_LOG_RESPONSES=true

# ── 7. Session ───────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_TURNS=20
LOG_SAFETY_VIOLATIONS=true

# ── 8. 应用设置 ──────────────────────────────────────────────
APP_NAME=Alice ADHD Robot
APP_LANGUAGE=zh-HK
DEBUG_MODE=false
STREAMLIT_PORT=8501

# ── 9. 应用密钥 ──────────────────────────────────────────────
SECRET_KEY=your_secret_key_here

# ── 10. HK Open Data（预留）──────────────────────────────────
MTR_CROWDING_API_URL=https://rt.data.gov.hk/v1/transport/mtr/line_route
NOISE_SENSOR_API_URL=https://data.gov.hk/en/noise-sensors